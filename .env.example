# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# Neon POOLED connection string. Used by both src/db/index.ts (neon-http)
# and src/db/tx.ts (Pool). Must include ?sslmode=require.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Better Auth signing secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-openssl-rand-base64-32-output"

# Better Auth base URL. http://localhost:3000 for local dev.
# In production this MUST be the EXACT deployed origin (scheme + host, no
# trailing slash) or Better Auth returns 403 on signup.
BETTER_AUTH_URL="http://localhost:3000"

# Anthropic API key from https://console.anthropic.com
# Read by @ai-sdk/anthropic (src/lib/ai-engine.ts).
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx"
